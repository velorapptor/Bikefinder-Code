prismamodel BikeReport {
  id          String   @id @default(cuid())
  bikeBrand   String
  bikeModel   String
  bikeColor   String
  frameNumber String?
  description String
  reward      Int      // finders fee in NOK
  status      String   @default("reported") // reported | found | claimed
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BountyClaim {
  id          String     @id @default(cuid())
  bikeReportId String
  finderId    String
  claimedAt   DateTime   @default(now())
  status      String     @default("pending") // pending | paid | rejected
