2. prisma/schema.prisma
prismagenerator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model BikeReport {
  id          String   @id @default(cuid())
  bikeBrand   String
  bikeModel   String
  bikeColor   String
  frameNumber String?
  description String?
  reward      Int      // Finders fee in NOK
  status      String   @default("reported") // reported | found | claimed | closed
  ownerId     String   // Fake user ID for now
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  claims      BountyClaim[]
}

model BountyClaim {
  id           String     @id @default(cuid())
  bikeReportId String
  finderId     String     // Fake finder ID
  claimedAt    DateTime   @default(now())
  status       String     @default("pending") // pending | approved | rejected | paid

  bikeReport   BikeReport @relation(fields: [bikeReportId], references: [id])

  @@unique([bikeReportId, finderId])
}
